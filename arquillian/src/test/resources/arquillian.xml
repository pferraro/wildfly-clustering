<arquillian xmlns="http://jboss.org/schema/arquillian" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jboss.org/schema/arquillian https://jboss.org/schema/arquillian/arquillian_1_0.xsd">
	<extension qualifier="OCI">
		<property name="oci:image">tomcat:latest</property>
		<property name="oci:network-mode">host</property>
		<property name="oci:start-message-pattern">.*\QServer startup in \E.*</property>
		<property name="ref:JMX_PORT">jmxPort</property>
		<property name="env:JAVA_OPTS">-Dcom.sun.management.jmxremote.port=$JMX_PORT -Dcom.sun.management.jmxremote.ssl=false -Dcom.sun.management.jmxremote.authenticate=false</property>
		<property name="file:${project.build.testOutputDirectory}/tomcat/conf">/usr/local/tomcat/conf</property>
		<property name="file:${project.build.testOutputDirectory}/tomcat/webapps">/usr/local/tomcat/webapps</property>
	</extension>
	<group qualifier="tomcat" default="true">
		<container qualifier="tomcat" mode="class">
			<configuration>
				<property name="bindHttpPort">${tomcat.http.port}</property>
				<property name="jmxPort">${tomcat.jmx.port}</property>
				<property name="user">admin</property>
				<property name="pass">admin</property>
			</configuration>
		</container>
	</group>
</arquillian>
